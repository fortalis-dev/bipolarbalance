<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="@color/on_surface"
            android:layout_marginStart="-12dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DATA POINTS"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create custom data points to track anything that matters to you — e.g. Kids (Yes/No), Water (Counter), Work hours (Hours)."
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_add_data_point"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add data point"
            android:layout_marginBottom="16dp" />

        <!-- Filled programmatically -->
        <LinearLayout
            android:id="@+id/metrics_management_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
