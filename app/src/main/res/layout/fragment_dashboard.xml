<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Day navigation bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_prev_day"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous day"
                android:src="@drawable/ic_chevron_left"
                android:tint="@color/primary" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Today" />

            <ImageButton
                android:id="@+id/btn_next_day"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next day"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/primary" />

        </LinearLayout>

        <!-- ── Quality card (compact) ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_quality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Balance Score"
                        android:textSize="12sp"
                        android:textColor="@android:color/white"
                        android:alpha="0.75" />

                    <TextView
                        android:id="@+id/tv_quality_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:text="No entry yet today" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_quality_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:text="—" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Balance Score over time graph ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Balance Score over time"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <com.bipolar.balance.QualityGraphView
                    android:id="@+id/quality_graph"
                    android:layout_width="match_parent"
                    android:layout_height="260dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Selected day detail card (shown when a day is tapped) ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_day_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/insight_card"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_day_detail_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="Selected day" />

                <TextView
                    android:id="@+id/tv_day_detail_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface"
                    android:alpha="0.85"
                    android:text="" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Extras / custom metrics ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_extras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA &amp; NOTES"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/extras_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Daily Drive Inputs graph ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_intraday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_intraday_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Daily Drive Inputs"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <com.bipolar.balance.IntraDayGraphView
                    android:id="@+id/intraday_graph"
                    android:layout_width="match_parent"
                    android:layout_height="160dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
