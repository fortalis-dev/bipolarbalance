<?xml version="1.0" encoding="utf-8"?>
<!-- Yes/No widget: tap anywhere to toggle — works at 1×1 and larger -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="4dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/tv_widget_metric_name"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Yes / No"
        android:textColor="#B0B0B0"
        android:textSize="10sp"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="5sp"
        android:autoSizeMaxTextSize="14sp" />

    <TextView
        android:id="@+id/tv_widget_metric_value"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:text="—"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="10sp"
        android:autoSizeMaxTextSize="52sp" />

    <TextView
        android:id="@+id/tv_widget_metric_unit"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="tap to toggle"
        android:textColor="#606060"
        android:textSize="8sp"
        android:gravity="center"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="5sp"
        android:autoSizeMaxTextSize="11sp" />

</LinearLayout>
