<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:id="@+id/settings_list_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Category: Data & Sync -->
            <TextView
                style="@style/TextAppearance.MaterialComponents.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Data &amp; Sync"
                android:textColor="@color/on_primary_container" />

            <include
                android:id="@+id/item_backup"
                layout="@layout/item_setting" />

            <include
                android:id="@+id/item_custom_data"
                layout="@layout/item_setting" />

            <!-- Category: App Configuration -->
            <TextView
                style="@style/TextAppearance.MaterialComponents.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Preferences"
                android:textColor="@color/on_primary_container" />

            <include
                android:id="@+id/item_widgets"
                layout="@layout/item_setting" />

            <include
                android:id="@+id/item_notifications"
                layout="@layout/item_setting" />

            <include
                android:id="@+id/item_toggle_suspend"
                layout="@layout/item_setting_switch" />

            <!-- Category: Future Features -->
            <TextView
                style="@style/TextAppearance.MaterialComponents.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Upcoming"
                android:textColor="@color/on_primary_container" />

            <include
                android:id="@+id/item_health_sync"
                layout="@layout/item_setting" />

            <!-- Category: Support -->
            <TextView
                style="@style/TextAppearance.MaterialComponents.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Support"
                android:textColor="@color/on_primary_container" />

            <include
                android:id="@+id/item_help"
                layout="@layout/item_setting" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
