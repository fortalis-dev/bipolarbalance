<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/background">

    <!-- Date header -->
    <TextView
        android:id="@+id/tv_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/on_surface"
        tools:text="Daily Entry – 2026-04-14" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/day_starts_at"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- ── Drive + Sleep bars at fixed height ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="270dp"
        android:orientation="horizontal">

        <!-- Drive column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/drive_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_drive_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"
                tools:text="Auto avg: 3.2" />

            <com.bipolar.balance.ThermoBarView
                android:id="@+id/bar_drive"
                android:layout_width="64dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_drive_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginTop="6dp"
                tools:text="Level: 4" />

            <Button
                android:id="@+id/btn_reset_drive"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_to_auto"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Suspend column -->
        <LinearLayout
            android:id="@+id/layout_suspend_col"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/label_suspend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/suspend_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="4dp" />

            <com.bipolar.balance.ThermoBarView
                android:id="@+id/bar_suspend"
                android:layout_width="64dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_suspend_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginTop="6dp"
                tools:text="8h" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Extras + Note (scrollable) ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <!-- Extras header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DATA POINTS"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tv_manage_metrics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage in Settings →"
                    android:textSize="11sp"
                    android:textColor="@color/primary"
                    android:alpha="0.7"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            <!-- Dynamic metric rows (filled programmatically) -->
            <LinearLayout
                android:id="@+id/metrics_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Note card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Header row: title + save button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NOTES"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textColor="@color/primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_note"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Save note"
                            android:textSize="12sp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>

                    <!-- Saved notes list (populated programmatically) -->
                    <LinearLayout
                        android:id="@+id/notes_list_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/primary"
                        android:alpha="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEW NOTE"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Write your note here…"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:maxLines="5"
                        android:background="@android:color/transparent"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="#A09090" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save indicator -->
    <TextView
        android:id="@+id/tv_saved_at"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginTop="6dp"
        tools:text="Saved at 14:32" />

</LinearLayout>
