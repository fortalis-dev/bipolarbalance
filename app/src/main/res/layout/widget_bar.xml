<?xml version="1.0" encoding="utf-8"?>
<!--
  Drive widget – each coloured segment is directly tappable to select that level.
  Level 7 is at the top, level 1 at the bottom (thermometer orientation).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="6dp"
    android:background="@drawable/widget_background">

    <!-- Level number at the top -->
    <TextView
        android:id="@+id/tv_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Bar: children are tappable rows; each gets equal weight -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- level 7 – top (hot/red) -->
        <TextView
            android:id="@+id/level7"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="2dp"
            android:background="#BDBDBD" />

        <TextView
            android:id="@+id/level6"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="2dp"
            android:background="#BDBDBD" />

        <TextView
            android:id="@+id/level5"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="2dp"
            android:background="#BDBDBD" />

        <TextView
            android:id="@+id/level4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="2dp"
            android:background="#BDBDBD" />

        <TextView
            android:id="@+id/level3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="2dp"
            android:background="#BDBDBD" />

        <TextView
            android:id="@+id/level2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="2dp"
            android:background="#BDBDBD" />

        <!-- level 1 – bottom (cold/blue) -->
        <TextView
            android:id="@+id/level1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#BDBDBD" />

    </LinearLayout>

</LinearLayout>

