<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Time range selector -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_7days"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last 7 days" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_30days"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last 30 days"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All time" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Drive / Sleep insight summary card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_insight_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/insight_card"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Drive · Sleep relationship"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <!-- High sleep stat -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/dot_lavender"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sleep ≥ 7 h"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_drive_high_sleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/quality_positive"
                        android:text="—" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" avg Drive"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"
                        android:alpha="0.65" />

                </LinearLayout>

                <!-- Low sleep stat -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/dot_rose"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sleep &lt; 7 h"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_drive_low_sleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/quality_negative"
                        android:text="—" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" avg Drive"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"
                        android:alpha="0.65" />

                </LinearLayout>

                <!-- Insight text -->
                <TextView
                    android:id="@+id/tv_insight_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface"
                    android:lineSpacingMultiplier="1.4"
                    android:background="@color/primary_container"
                    android:padding="12dp"
                    android:text="Add more entries to see insights."
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Lag effect cards -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_lag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Sleep lag effect on Drive"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tv_lag_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface"
                    android:lineSpacingMultiplier="1.5"
                    android:text="" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Drive + Sleep trend chart -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- legend row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto Drive · Sleep over time"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <!-- Drive legend -->
                    <View android:layout_width="24dp" android:layout_height="3dp"
                        android:background="@color/primary" android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Daily" android:textSize="11sp" android:textColor="@color/primary"
                        android:layout_marginEnd="10dp"/>

                    <!-- Auto drive legend -->
                    <View android:layout_width="24dp" android:layout_height="3dp"
                        android:background="#D4916C" android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Auto" android:textSize="11sp" android:textColor="#D4916C"
                        android:layout_marginEnd="10dp"/>

                    <!-- Sleep legend -->
                    <View android:layout_width="24dp" android:layout_height="3dp"
                        android:background="@color/quality_suspend" android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sleep" android:textSize="11sp" android:textColor="@color/quality_suspend"/>

                </LinearLayout>

                <com.bipolar.balance.InsightsTrendView
                    android:id="@+id/trend_view"
                    android:layout_width="match_parent"
                    android:layout_height="280dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Correlations with Drive ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_correlations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/insight_card"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correlations with Drive"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_correlation_note"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="10dp"
                    android:text="Pearson r on overlapping days" />

                <LinearLayout
                    android:id="@+id/correlations_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
